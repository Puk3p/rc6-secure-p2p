#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

# Files staged for commit
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# 1. Block forbidden generated/temp files
FORBIDDEN_FILES=$(echo "$STAGED_FILES" | grep -E '\.(class|log|tmp)$' || true)
if [ -n "$FORBIDDEN_FILES" ]; then
  echo "Error: forbidden files are staged:"
  echo "$FORBIDDEN_FILES"
  exit 1
fi

# 2. Block very large files (> 5 MB)
LARGE_FILES=""
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file")
    if [ "$size" -gt 5242880 ]; then
      LARGE_FILES="${LARGE_FILES}\n$file"
    fi
  fi
done

if [ -n "$LARGE_FILES" ]; then
  echo "Error: large files detected (> 5MB):"
  echo -e "$LARGE_FILES"
  exit 1
fi

# 3. Check trailing whitespace in text-like files
TEXT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(java|xml|md|properties|txt|yml|yaml|gitignore)$' || true)
for file in $TEXT_FILES; do
  if [ -f "$file" ]; then
    if grep -nE ' +$' "$file" >/dev/null; then
      echo "Error: trailing spaces found in $file"
      grep -nE ' +$' "$file"
      exit 1
    fi
  fi
done

# 4. Basic Maven compile check
echo "Running Maven compile check..."
mvn -q -DskipTests compile

echo "pre-commit passed."