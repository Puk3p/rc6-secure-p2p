#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

FORBIDDEN_FILES=$(echo "$STAGED_FILES" | grep -E '\.(class|log|tmp)$' || true)
if [ -n "$FORBIDDEN_FILES" ]; then
  echo "Error: forbidden files are staged:"
  echo "$FORBIDDEN_FILES"
  exit 1
fi

LARGE_FILES=""
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file")
    if [ "$size" -gt 5242880 ]; then
      LARGE_FILES="${LARGE_FILES}\n$file"
    fi
  fi
done

if [ -n "$LARGE_FILES" ]; then
  echo "Error: large files detected (> 5MB):"
  echo -e "$LARGE_FILES"
  exit 1
fi

TEXT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(java|xml|md|properties|txt|yml|yaml|gitignore|sh|ps1)$' || true)

MISSING_NEWLINE=""
for file in $TEXT_FILES; do
  if [ -f "$file" ] && [ -s "$file" ]; then
    if [ "$(tail -c 1 "$file" | wc -l)" -eq 0 ]; then
      MISSING_NEWLINE="${MISSING_NEWLINE}\n  $file"
    fi
  elif [ -f "$file" ] && [ ! -s "$file" ]; then
    MISSING_NEWLINE="${MISSING_NEWLINE}\n  $file (empty, no newline)"
  fi
done

if [ -n "$MISSING_NEWLINE" ]; then
  echo "Error: missing final newline in:"
  echo -e "$MISSING_NEWLINE"
  echo ""
  echo "Fix: run 'bash scripts/fix-eof.sh' (macOS/Linux) or 'powershell scripts/fix-eof.ps1' (Windows)"
  exit 1
fi

for file in $TEXT_FILES; do
  if [ -f "$file" ]; then
    if grep -nE ' +$' "$file" >/dev/null; then
      echo "Error: trailing spaces found in $file"
      grep -nE ' +$' "$file"
      exit 1
    fi
  fi
done

echo "Running Maven compile check..."

run_maven_compile() {
  case "$(uname -s)" in
    Linux*|Darwin*)
      if [ -f "./mvnw" ]; then
        chmod +x ./mvnw 2>/dev/null || true
        ./mvnw -q -DskipTests compile
      elif command -v mvn >/dev/null 2>&1; then
        mvn -q -DskipTests compile
      else
        echo "Error: Maven not found."
        exit 1
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      if [ -f "./mvnw.cmd" ]; then
        cmd.exe /c mvnw.cmd -q -DskipTests compile
      elif command -v mvn >/dev/null 2>&1; then
        mvn -q -DskipTests compile
      else
        echo "Error: Maven not found."
        exit 1
      fi
      ;;
    *)
      if command -v mvn >/dev/null 2>&1; then
        mvn -q -DskipTests compile
      else
        echo "Error: Unsupported OS and Maven not found."
        exit 1
      fi
      ;;
  esac
}

run_maven_compile

echo "pre-commit passed."
