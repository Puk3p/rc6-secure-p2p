#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files."
  exit 0
fi

FORBIDDEN_FILES=$(echo "$STAGED_FILES" | grep -E '\.(class|log|tmp)$' || true)
if [ -n "$FORBIDDEN_FILES" ]; then
  echo "Error: forbidden files are staged:"
  echo "$FORBIDDEN_FILES"
  exit 1
fi

LARGE_FILES=""
while IFS= read -r file; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file")
    if [ "$size" -gt 5242880 ]; then
      LARGE_FILES="${LARGE_FILES}\n$file"
    fi
  fi
done <<< "$STAGED_FILES"

if [ -n "$LARGE_FILES" ]; then
  echo "Error: large files detected (>5MB):"
  echo -e "$LARGE_FILES"
  exit 1
fi

TEXT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(java|xml|md|properties|txt|yml|yaml|gitignore|sh|ps1)$' || true)

MISSING_NEWLINE=""
for file in $TEXT_FILES; do
  if [ -f "$file" ] && [ -s "$file" ]; then
    if [ "$(tail -c 1 "$file" | wc -l)" -eq 0 ]; then
      MISSING_NEWLINE="${MISSING_NEWLINE}\n  $file"
    fi
  elif [ -f "$file" ] && [ ! -s "$file" ]; then
    MISSING_NEWLINE="${MISSING_NEWLINE}\n  $file (empty, no newline)"
  fi
done

if [ -n "$MISSING_NEWLINE" ]; then
  echo "Error: missing final newline in:"
  echo -e "$MISSING_NEWLINE"
  echo ""
  echo "Fix: run 'bash scripts/fix-eof.sh' (macOS/Linux) or 'powershell scripts/fix-eof.ps1' (Windows)"
  exit 1
fi

for file in $TEXT_FILES; do
  if [ -f "$file" ]; then
    if grep -nE ' +$' "$file" >/dev/null; then
      echo "Error: trailing spaces found in $file"
      grep -nE ' +$' "$file"
      exit 1
    fi
  fi
done <<< "$TEXT_FILES"

echo "Checking newline at end of file..."

EOF_FILES=$(echo "$STAGED_FILES" | grep -E '\.(java|xml|md|properties|txt|yml|yaml|gitignore|sh|ps1)$' || true)
FIXED_EOF_FILES=""

while IFS= read -r file; do
  [ -z "$file" ] && continue

  if [ ! -f "$file" ]; then
    continue
  fi

  if [ ! -s "$file" ]; then
    continue
  fi

  last_byte=$(tail -c 1 "$file" | od -An -t x1 | tr -d '[:space:]')

  if [ "$last_byte" != "0a" ]; then
    echo "Fixing missing newline at end of file: $file"
    printf '\n' >> "$file"
    git add "$file"
    FIXED_EOF_FILES="${FIXED_EOF_FILES}\n$file"
  fi
done <<< "$EOF_FILES"

if [ -n "$FIXED_EOF_FILES" ]; then
  echo "Auto-fixed files:"
  echo -e "$FIXED_EOF_FILES"
fi

run_maven() {
  local ARGS="$*"
  case "$(uname -s)" in
    Linux*|Darwin*)
      if [ -f "./mvnw" ]; then
        chmod +x ./mvnw 2>/dev/null || true
        ./mvnw $ARGS
      elif command -v mvn >/dev/null 2>&1; then
        mvn $ARGS
      else
        echo "Error: Maven not found."
        exit 1
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      if [ -f "./mvnw.cmd" ]; then
        cmd.exe /c mvnw.cmd $ARGS
      elif command -v mvn >/dev/null 2>&1; then
        mvn $ARGS
      else
        echo "Error: Maven not found."
        exit 1
      fi
      ;;
    *)
      if command -v mvn >/dev/null 2>&1; then
        mvn $ARGS
      else
        echo "Error: Unsupported OS and Maven not found."
        exit 1
      fi
      ;;
  esac
}

echo "Running Spotless format check..."
if ! run_maven -q spotless:check; then
  echo ""
  echo "Error: code is not formatted correctly."
  echo ""
  echo "Fix: run 'mvn spotless:apply' to auto-format all files."
  echo "     (or './mvnw spotless:apply' / 'mvnw.cmd spotless:apply')"
  exit 1
fi

echo "Running Maven compile check..."
run_maven -q -DskipTests compile

echo "pre-commit passed."
