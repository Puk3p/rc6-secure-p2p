#!/usr/bin/env bash
set -e

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "Running pre-push checks..."

if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "Error: direct push to 'main' is not allowed."
  echo "Create a feature branch and open a Pull Request."
  exit 1
fi

run_maven() {
  local ARGS="$*"
  case "$(uname -s)" in
    Linux*|Darwin*)
      if [ -f "./mvnw" ]; then
        chmod +x ./mvnw 2>/dev/null || true
        ./mvnw $ARGS
      elif command -v mvn >/dev/null 2>&1; then
        mvn $ARGS
      else
        echo "Error: Maven not found."
        exit 1
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      if [ -f "./mvnw.cmd" ]; then
        cmd.exe /c mvnw.cmd $ARGS
      elif command -v mvn >/dev/null 2>&1; then
        mvn $ARGS
      else
        echo "Error: Maven not found."
        exit 1
      fi
      ;;
    *)
      if command -v mvn >/dev/null 2>&1; then
        mvn $ARGS
      else
        echo "Error: Unsupported OS and Maven not found."
        exit 1
      fi
      ;;
  esac
}

echo "Running Spotless format check..."
if ! run_maven -q spotless:check; then
  echo ""
  echo "Error: code is not formatted correctly."
  echo "Fix: run 'mvn spotless:apply' to auto-format all files."
  exit 1
fi

echo "Running Maven tests..."
run_maven -q clean test

echo "pre-push passed."
